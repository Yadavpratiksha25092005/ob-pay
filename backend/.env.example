# ─── Database ───────────────────────────────────────────────────────────────
# Option A: full Postgres URL
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/obpay_db?sslmode=disable

# Option B: password only (host/port/user/dbname stay at defaults)
DB_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ─── Firebase / FCM ─────────────────────────────────────────────────────────
FIREBASE_CREDENTIALS_FILE=serviceAccountKey.json

# ─── Admin Setup ─────────────────────────────────────────────────────────────
# One-time secret to promote a user to admin — change before deploying
ADMIN_SETUP_SECRET=

# ─── CORS / Environment ──────────────────────────────────────────────────────
APP_ENV=development
# Comma-separated allowed origins (leave blank to use APP_ENV defaults)
ALLOWED_ORIGINS=
